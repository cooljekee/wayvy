# Copy to .env and fill in real values. Never commit .env

# SMSAero (https://smsaero.ru)
SMSAERO_EMAIL=your@email.com
SMSAERO_API_KEY=your_key_here          # prod key from smsaero.ru account
SMSAERO_API_KEY_TEST=your_test_key     # test key, OTPs go to smsaero dashboard

# Yandex MapKit (iOS — set in Xcode, not in .env)
# YANDEX_MAPKIT_KEY=your_key           # set in AppDelegate/App.init, read from xcconfig

# PostgreSQL
DATABASE_URL=postgres://wayvy:wayvy@localhost:5432/wayvy?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# JWT
JWT_SECRET=change_me_in_production

# Cloudflare R2
R2_ACCESS_KEY_ID=your_key
R2_SECRET_ACCESS_KEY=your_secret
R2_BUCKET=wayvy-media
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://media.wayvy.app
