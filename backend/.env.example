POSTGRES_DB=wayvy
POSTGRES_USER=wayvy
POSTGRES_PASSWORD=change_me_in_prod
DATABASE_URL=postgres://wayvy:change_me_in_prod@localhost:5432/wayvy?sslmode=disable
REDIS_ADDR=localhost:6379
JWT_SECRET=change_me_32_chars_minimum_here__
SMSAERO_EMAIL=your@email.com
SMSAERO_API_KEY=your_prod_key
SMSAERO_API_KEY_TEST=your_test_key
PORT=8081

# Cloudflare R2 (media-service)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=wayvy-media
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_URL=https://media.wayvy.app
